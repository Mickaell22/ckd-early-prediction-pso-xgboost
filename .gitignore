# Datos crudos (descargar segun data/raw/README.md)
data/raw/*
!data/raw/README.md
# El dataset UCI (~43 KB, CC BY 4.0) si se versiona por reproducibilidad
!data/raw/ckd_uci.csv

# Datos procesados (se regeneran con los scripts)
data/processed/*
!data/processed/.gitkeep

# Resultados generados (modelos, figuras, metricas)
results/figures/*
!results/figures/.gitkeep
results/models/*
!results/models/.gitkeep
results/*.json
results/*.csv

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/

# Entornos virtuales
venv/
.venv/
env/

# Jupyter
.ipynb_checkpoints/

# Variables de entorno
.env

