# Datos crudos (descargar segun data/raw/README.md)
data/raw/*
!data/raw/README.md
# El dataset UCI (~43 KB, CC BY 4.0) si se versiona por reproducibilidad
!data/raw/ckd_uci.csv

# Datos procesados (se regeneran con los scripts)
data/processed/*
!data/processed/.gitkeep

# Resultados generados
# Las figuras y las metricas SI se versionan para poder verlas en GitHub sin re-ejecutar.
results/figures/*
!results/figures/.gitkeep
!results/figures/*.png
# Los modelos serializados (binarios, regenerables) NO se versionan.
results/models/*
!results/models/.gitkeep

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/

# Entornos virtuales
venv/
.venv/
env/

# Jupyter
.ipynb_checkpoints/

# Variables de entorno
.env

# IDE / SO
.vscode/
.idea/
.DS_Store

# Claude Code
.claude/

# Logs
*.log
